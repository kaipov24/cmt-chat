NODE_ENV=development
PORT=4000
JWT_ACCESS_SECRET=replace-with-a-long-random-local-development-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-local-development-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
DATABASE_URL=postgresql://cmt:cmt@localhost:5432/cmt?schema=public
SHADOW_DATABASE_URL=postgresql://cmt:cmt@localhost:5432/cmt_shadow?schema=public
REDIS_URL=redis://localhost:6379
FRONTEND_ORIGIN=http://localhost:3000
