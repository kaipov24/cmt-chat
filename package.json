{
  "name": "cmt-community-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm --recursive run build",
    "db:deploy": "pnpm --filter @cmt/backend run db:deploy",
    "db:migrate": "pnpm --filter @cmt/backend run db:migrate",
    "db:seed": "pnpm --filter @cmt/backend run db:seed",
    "db:studio": "pnpm --filter @cmt/backend run db:studio",
    "dev": "pnpm --parallel --filter @cmt/frontend --filter @cmt/backend run dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "pnpm --recursive run lint",
    "typecheck": "pnpm --recursive run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@next/eslint-plugin-next": "^15.1.4",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.4",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
